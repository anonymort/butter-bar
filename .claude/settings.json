{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(gh pr:*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/pr-lifecycle-hook.sh",
            "timeout": 15,
            "statusMessage": "Checking PR lifecycle..."
          }
        ]
      }
    ]
  }
}
